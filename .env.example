# ==========================================
# Multi-Agent Paper Improvement System
# Environment Configuration
# ==========================================

# Server Configuration
PORT=3000
NODE_ENV=development
REVIEW_MAX_CONCURRENCY=1
WORKFLOW_ENGINE=CLASSIC
RL_MAX_ROUNDS=3
RL_EXPLORATION_RATE=0.2
RL_LEARNING_RATE=0.35
RL_REWARD_THRESHOLD=0.6

# Database Configuration (SQLite)
DATABASE_URL="file:./dev.db"

# ==========================================
# Agent LLM Configurations
# User can customize API URL and Keys here
# ==========================================

# 1. Chief Editor Agent (General Orchestrator)
CHIEF_API_URL=https://api.openai.com/v1
CHIEF_API_KEY=your_openai_api_key_here
CHIEF_MODEL=gpt-4o

# 2. Structure Agent
STRUCTURE_API_URL=https://api.openai.com/v1
STRUCTURE_API_KEY=your_openai_api_key_here
STRUCTURE_MODEL=gpt-4-turbo

# 3. Logic Agent
LOGIC_API_URL=https://api.openai.com/v1
LOGIC_API_KEY=your_openai_api_key_here
LOGIC_MODEL=gpt-4-turbo

# 4. Literature Agent
LITERATURE_API_URL=https://api.openai.com/v1
LITERATURE_API_KEY=your_openai_api_key_here
LITERATURE_MODEL=gpt-4-turbo

# 5. Writing Agent
WRITING_API_URL=https://api.openai.com/v1
WRITING_API_KEY=your_openai_api_key_here
WRITING_MODEL=gpt-4-turbo
